{
	"info": {
		"_postman_id": "8b5f3a09-7d88-46eb-8e2b-22db345a995e",
		"name": "Aegis Task Manager API",
		"description": "Comprehensive API collection for testing the Aegis Task Manager REST API with Role-Based Access Control and Token Authorization.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Register User",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"testuser@aegis.com\",\n    \"password\": \"userpassword123\",\n    \"full_name\": \"Test User\",\n    \"role\": \"user\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/register",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"register"
							]
						},
						"description": "Registers a new user into the database. Password is securely hashed using bcrypt."
					},
					"response": []
				},
				{
					"name": "Login & Get Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.access_token) {",
									"    pm.collectionVariables.set(\"jwtToken\", jsonData.access_token);",
									"    console.log(\"Saved access token to collection variables!\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/x-www-form-urlencoded"
							}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{
									"key": "username",
									"value": "admin@aegis.com",
									"type": "text"
								},
								{
									"key": "password",
									"value": "admin123",
									"type": "text"
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/login",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"auth",
								"login"
							]
						},
						"description": "Exchanges standard email (username) and password for a JWT token with role claims. Contains an automated test script that binds the token to the collection session."
					},
					"response": []
				}
			]
		},
		{
			"name": "Users (RBAC Checks)",
			"item": [
				{

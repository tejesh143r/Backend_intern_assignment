						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwtToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/users/me",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"users",
								"me"
							]
						},
						"description": "Fetch the currently authenticated user's profile information."
					},
					"response": []
				},
				{
					"name": "List All Users [Admin Only]",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwtToken}}",
									"type": "string"
								}
							]
						},
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/users/",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"users",
								""
							]
						},
						"description": "Lists all users in the system. Enforces role-based permissions (admin only)."
					},
					"response": []
				},
				{
					"name": "Update User Role [Admin Only]",
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
								{
									"key": "token",
									"value": "{{jwtToken}}",
									"type": "string"
								}
							]
						},
						"method": "PUT",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/users/1/role?new_role=admin",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"users",
								"1",
								"role"
							],
							"query": [
								{
									"key": "new_role",
									"value": "admin",
									"description": "Can be 'admin' or 'user'"
								}
							]
						},
						"description": "Updates another user's authorization role. Enforces role-based access checks (admin only)."
					},
					"response": []
				}
			]
		},
